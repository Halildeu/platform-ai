# Host-local env overrides for live-stt (SECRETS) — copy to env.local.ps1.
# env.local.ps1 is GITIGNORED: passwords never enter the repo.
#
# Stage-2 staging run (#57/#151) — fill <...> from the secure channel
# (Vault kv/platform/audio-gateway-service: redis_password):
#
# $env:STT_CHUNK_CONSUMER_ENABLED = "true"
# $env:STT_REDIS_URL = "redis://:<redis_password>@<staging-sw-LAN-IP>:6379/0"
#
# Optional non-secret local tuning if the GPU/model cache needs a different
# cold-load budget than the repo default in start-live-stt.ps1:
#
# $env:STT_REQUEST_TIMEOUT = "180"
#
# Remove/comment these after the run to detach from staging.
